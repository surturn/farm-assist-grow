generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CropStatus {
  PLANNED
  GROWING
  HARVESTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id            String          @id @default(cuid())
  firebaseUid   String          @unique
  email         String          @unique
  displayName   String?
  farmsOwned    Farm[]          @relation("FarmOwner")
  farmMemberships FarmMember[]
  tasksAssigned Task[]          @relation("TaskAssignee")
  notifications Notification[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Farm {
  id          String       @id @default(cuid())
  name        String
  location    String?
  ownerId     String
  owner       User         @relation("FarmOwner", fields: [ownerId], references: [id])
  members     FarmMember[]
  crops       Crop[]
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FarmMember {
  id        String   @id @default(cuid())
  farmId    String
  userId    String
  role      String   @default("viewer")
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([farmId, userId])
}

model Crop {
  id        String     @id @default(cuid())
  farmId    String
  name      String
  status    CropStatus @default(PLANNED)
  farm      Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Task {
  id          String     @id @default(cuid())
  farmId       String
  cropId       String?
  assigneeId   String?
  title        String
  description  String?
  dueDate      DateTime?
  status       TaskStatus @default(TODO)
  farm         Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop         Crop?       @relation(fields: [cropId], references: [id], onDelete: SetNull)
  assignee     User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
